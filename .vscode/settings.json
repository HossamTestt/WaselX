{
  "java.project.sourcePaths": [],
  "files.exclude": {
    "**/node_modules": true,
    "**/.expo": true
  },

  "java.project.referencedLibraries": [],
  "java.import.exclusions": [
    "**/node_modules/**",
    "**/android/**",
    "**/.gradle/**",
    "**/build/**"
  ],
  "search.exclude": {
    "**/node_modules": true,
    "**/android/build": true,
    "**/.gradle": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/android/.gradle/**": true,
    "**/android/build/**": true
  },
  "gradle.nestedProjects": false,
  "gradle.autoDetect": "off",
  "java.configuration.updateBuildConfiguration": "disabled",
  "java.server.launchMode": "LightWeight",
  "groovy.validate": false,
  "githubActions.validators.checkout": false
}
